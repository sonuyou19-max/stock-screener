# ─────────────────────────────────────────────────────────────
# Indian Stock Screener — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains your credentials.
# ─────────────────────────────────────────────────────────────

# ── Alert Email (Gmail) ──────────────────────────────────────
# Your Gmail address (the one sending alerts)
ALERT_EMAIL_FROM=your@gmail.com

# Gmail App Password (NOT your main Gmail password)
# Generate at: Google Account → Security → App Passwords
# Select "Mail" and your device, copy the 16-character password
ALERT_EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Email address to receive alerts (can be same as FROM)
ALERT_EMAIL_TO=your@gmail.com

# ── Screener Config ──────────────────────────────────────────
# Total investment budget in INR
BUDGET=100000

# ── Railway Config (set these in Railway dashboard) ──────────
# PORT is auto-set by Railway — do not change
# PORT=8000
